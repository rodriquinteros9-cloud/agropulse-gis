# Configuración CORS
# Lista de orígenes permitidos separados por comas
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Google Earth Engine Project ID
EE_PROJECT=your-gee-project-id

# ROFEX / MATba-ROFEX Credentials
# Obtener credenciales en: https://www.rofex.com.ar/desarrolladores
ROFEX_ACCOUNT=your_account
ROFEX_PASSWORD=your_password
ROFEX_API_KEY=your_api_key
ROFEX_ENVIRONMENT=paper  # "paper" para testing, "live" para producción
